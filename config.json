{
  "name": "Octopus Export Optimizer",
  "version": "0.9.0",
  "init": false,
  "slug": "octopus_export_optimizer",
  "description": "Optimizes electricity export on Octopus Agile/Variable tariffs with FoxESS inverter",
  "url": "https://github.com/batesyx/ha-agile-solar",
  "arch": ["aarch64", "amd64"],
  "image": "ghcr.io/batesyx/ha-agile-solar-{arch}",
  "startup": "application",
  "boot": "auto",
  "hassio_api": true,
  "homeassistant_api": true,
  "services": ["mqtt:want"],
  "ports": {
    "8099/tcp": 8099
  },
  "ports_description": {
    "8099/tcp": "Data export API"
  },
  "map": ["share:rw"],
  "options": {
    "octopus_api_key": "",
    "octopus_account_number": "",
    "export_mpan": "",
    "export_serial": "",
    "import_mpan": "",
    "import_serial": "",
    "export_product_code": "AGILE-OUTGOING-19-05-13",
    "export_tariff_code": "E-1R-AGILE-OUTGOING-19-05-13-A",
    "import_product_code": "INTELLI-VAR-24-10-29",
    "import_tariff_code": "E-1R-INTELLI-VAR-24-10-29-A",
    "battery_capacity_kwh": 11.52,
    "flat_export_rate_pence": 12.0,
    "export_now_threshold_pence": 15.0,
    "inverter_control_enabled": false,
    "cheap_rate_start_hour": 23.5,
    "cheap_rate_end_hour": 5.5,
    "export_planner_enabled": false,
    "max_discharge_kw": 5.0,
    "solar_overnight_enabled": false,
    "minimum_overnight_soc_pct": 0.40,
    "solar_months_max_soc_pct": 0.80,
    "winter_max_soc_pct": 0.95,
    "solar_charge_kwh_per_slot": 0.75,
    "solar_forecast_minimum_kwh": 10.0,
    "solar_forecast_today_entity": "",
    "solar_forecast_tomorrow_entity": ""
  },
  "schema": {
    "octopus_api_key": "password",
    "octopus_account_number": "str",
    "export_mpan": "str",
    "export_serial": "str",
    "import_mpan": "str",
    "import_serial": "str",
    "export_product_code": "str",
    "export_tariff_code": "str",
    "import_product_code": "str",
    "import_tariff_code": "str",
    "battery_capacity_kwh": "float",
    "flat_export_rate_pence": "float",
    "export_now_threshold_pence": "float",
    "inverter_control_enabled": "bool",
    "cheap_rate_start_hour": "float",
    "cheap_rate_end_hour": "float",
    "export_planner_enabled": "bool",
    "max_discharge_kw": "float",
    "solar_overnight_enabled": "bool",
    "minimum_overnight_soc_pct": "float",
    "solar_months_max_soc_pct": "float",
    "winter_max_soc_pct": "float",
    "solar_charge_kwh_per_slot": "float",
    "solar_forecast_minimum_kwh": "float",
    "solar_forecast_today_entity": "str",
    "solar_forecast_tomorrow_entity": "str"
  }
}
