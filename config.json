{
  "name": "Octopus Export Optimizer",
  "version": "0.1.3",
  "slug": "octopus_export_optimizer",
  "description": "Optimizes electricity export on Octopus Agile/Variable tariffs with FoxESS inverter",
  "url": "https://github.com/batesyx/ha-agile-solar",
  "arch": ["aarch64", "amd64"],
  "image": "ghcr.io/batesyx/ha-agile-solar-{arch}",
  "startup": "application",
  "boot": "auto",
  "hassio_api": true,
  "homeassistant_api": true,
  "services": ["mqtt:want"],
  "map": ["share:rw"],
  "options": {
    "octopus_api_key": "",
    "octopus_account_number": "",
    "export_mpan": "",
    "export_serial": "",
    "import_mpan": "",
    "import_serial": "",
    "export_product_code": "AGILE-OUTGOING-19-05-13",
    "export_tariff_code": "E-1R-AGILE-OUTGOING-19-05-13-A",
    "import_product_code": "INTELLI-VAR-24-10-29",
    "import_tariff_code": "E-1R-INTELLI-VAR-24-10-29-A",
    "battery_capacity_kwh": 11.52,
    "flat_export_rate_pence": 12.0,
    "export_now_threshold_pence": 15.0
  },
  "schema": {
    "octopus_api_key": "password",
    "octopus_account_number": "str",
    "export_mpan": "str",
    "export_serial": "str",
    "import_mpan": "str",
    "import_serial": "str",
    "export_product_code": "str",
    "export_tariff_code": "str",
    "import_product_code": "str",
    "import_tariff_code": "str",
    "battery_capacity_kwh": "float",
    "flat_export_rate_pence": "float",
    "export_now_threshold_pence": "float"
  }
}
